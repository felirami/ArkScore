# Shared local defaults. Copy values into app-specific .env files as needed.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CREDIT_SCORE_REGISTRY_ADDRESS=
NEXT_PUBLIC_EERC20_DEMO_ADDRESS=
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false

# Deployment verification helpers
ARKSCORE_WEB_URL=https://arkscore-seven.vercel.app
ARKSCORE_API_URL=
ARKSCORE_REGISTRY_ADDRESS=
ARKSCORE_EERC20_DEMO_ADDRESS=
ARKSCORE_SCORER_ADDRESS=
ARKSCORE_REQUIRE_WAVY=false
ARKSCORE_REQUIRE_EERC20=false
ARKSCORE_REQUIRE_SCORE_RECORD=false
# Optional custom output/read path. The default path is optional until pnpm record:fuji writes it.
ARKSCORE_SCORE_RECORD_ARTIFACT=packages/contracts/deployments/fuji/LatestScoreRecord.json
ARKSCORE_ALLOW_MOCK_RECORD=false
ARKSCORE_TEST_WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
EERC20_REPO_DIR=../EncryptedERC
EERC20_MODE=standalone
VERCEL_SCOPE=feliramis-projects
VERCEL_PROJECT_NAME=arkscore
VERCEL_TOKEN=
RAILWAY_PROJECT_NAME=arkscore-api
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE=arkscore-api
RAILWAY_ENVIRONMENT=production
RAILWAY_WORKSPACE=
RAILWAY_TOKEN=
RAILWAY_ALLOW_MOCK=false

# Backend
WAVY_NODE_API_KEY=ApiKey wavy_replace_with_wavy_node_api_key
WAVY_NODE_PROJECT_ID=replace_with_wavy_node_project_id
WAVY_NODE_BASE_URL=https://api.wavynode.com/v1
WAVY_NODE_CHAIN_ID=43114
WAVY_NODE_TIMEOUT_MS=15000
WAVY_NODE_ANALYSIS_POLL_INTERVAL_MS=2000
WAVY_NODE_ANALYSIS_POLL_TIMEOUT_MS=90000
WAVY_NODE_AUTO_REGISTER=true
WAVY_NODE_FOREIGN_USER_PREFIX=arkscore-wallet
WAVY_NODE_MOCK_MODE=auto
WAVY_NODE_INTEGRATION_SECRET=replace_with_wavy_node_integration_secret
WAVY_NODE_INTEGRATION_TIME_TOLERANCE_MS=300000
WAVY_NODE_INTEGRATION_USER_DATA_JSON={"givenName":"replace_with_given_name","maternalSurname":"replace_with_maternal_surname","paternalSurname":"replace_with_paternal_surname","birthdate":"1992-05-15","nationality":"MX","phoneNumber":{"countryCode":"+52","phoneNumber":5512345678},"email":"replace_with_email@example.com","address":{"country":"MX","region":"CDMX","city":"Ciudad de Mexico","street":"replace_with_street","colonia":"replace_with_colonia","exteriorNumber":"123","postalCode":"06100"}}
ARKSCORE_SCORE_RATE_LIMIT_MAX=120
ARKSCORE_SCORE_RATE_LIMIT_WINDOW_MS=60000
ARKSCORE_SUBJECT_HASH_SALT=replace_with_long_random_subject_hash_salt
PORT=4000

# Contracts
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
FUJI_PRIVATE_KEY=
ARKSCORE_SCORER_PRIVATE_KEY=
FUJI_SCORER_PRIVATE_KEY=
SCORER_ADDRESS=
SCORER_AUTHORIZED=true
