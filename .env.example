# Shared local defaults. Copy values into app-specific .env files as needed.

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
NEXT_PUBLIC_CREDIT_SCORE_REGISTRY_ADDRESS=
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false

# Deployment verification helpers
ARKSCORE_WEB_URL=https://arkscore-seven.vercel.app
ARKSCORE_API_URL=
ARKSCORE_REGISTRY_ADDRESS=
ARKSCORE_SCORER_ADDRESS=
ARKSCORE_REQUIRE_WAVY=false
ARKSCORE_ALLOW_MOCK_RECORD=false
ARKSCORE_TEST_WALLET=0xd8dA6BF26964aF9D7eEd9e03E53415D37aA96045
VERCEL_SCOPE=feliramis-projects
VERCEL_PROJECT_NAME=arkscore
VERCEL_TOKEN=
RAILWAY_PROJECT_NAME=arkscore-api
RAILWAY_PROJECT_ID=
RAILWAY_SERVICE=arkscore-api
RAILWAY_ENVIRONMENT=production
RAILWAY_WORKSPACE=
RAILWAY_TOKEN=
