{
  "name": "arkscore",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-preserving on-chain credit and investor risk scoring oracle for Avalanche Fuji.",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "pnpm --filter @arkscore/web dev",
    "dev:web": "pnpm --filter @arkscore/web dev",
    "dev:api": "pnpm --filter @arkscore/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify": "pnpm scripts:typecheck && pnpm scripts:test && pnpm verify:railway && pnpm -r lint && pnpm -r test && pnpm -r build && pnpm -r typecheck",
    "scripts:typecheck": "tsc --noEmit --skipLibCheck --module NodeNext --moduleResolution NodeNext --target ES2022 --types node scripts/*.ts",
    "scripts:test": "tsx --test scripts/*.test.ts",
    "verify:railway": "tsx scripts/verify-railway-archive.ts",
    "audit:requirements": "tsx scripts/audit-requirements.ts",
    "audit:requirements:strict": "tsx scripts/audit-requirements.ts --strict",
    "judge:demo": "tsx scripts/judge-demo.ts",
    "readiness": "tsx scripts/readiness-check.ts",
    "readiness:strict": "tsx scripts/readiness-check.ts --strict",
    "readiness:strict:record": "tsx scripts/readiness-check.ts --strict --require-score-record",
    "probe:wavy": "tsx scripts/probe-wavy.ts",
    "probe:fuji": "pnpm --filter @arkscore/contracts probe:fuji",
    "plan:eerc20": "tsx scripts/plan-eerc20.ts",
    "probe:eerc20": "tsx scripts/probe-eerc20.ts",
    "probe:eerc20:strict": "tsx scripts/probe-eerc20.ts --strict",
    "record:fuji": "pnpm --filter @arkscore/contracts record-live-score:fuji",
    "verify:railway:live": "tsx scripts/verify-live.ts --skip-web --skip-contract --skip-eerc20 --strict --require-wavy",
    "verify:live": "tsx scripts/verify-live.ts",
    "verify:live:preflight": "tsx scripts/verify-live.ts --skip-web --strict --require-wavy",
    "verify:live:preflight:record": "tsx scripts/verify-live.ts --skip-web --strict --require-wavy --require-score-record",
    "verify:live:strict": "tsx scripts/verify-live.ts --strict --require-wavy",
    "verify:live:strict:record": "tsx scripts/verify-live.ts --strict --require-wavy --require-score-record",
    "verify:live:strict:eerc20": "tsx scripts/verify-live.ts --strict --require-wavy --require-eerc20",
    "verify:live:strict:eerc20:record": "tsx scripts/verify-live.ts --strict --require-wavy --require-eerc20 --require-score-record",
    "smoke:web": "tsx scripts/smoke-hosted-demo.ts",
    "submission:evidence": "tsx scripts/submission-evidence.ts",
    "submission:evidence:full": "tsx scripts/submission-evidence.ts --include-verify",
    "submission:evidence:write": "tsx scripts/submission-evidence.ts --write",
    "submission:evidence:write:full": "tsx scripts/submission-evidence.ts --write --include-verify",
    "finalize:live": "tsx scripts/finalize-live.ts",
    "finalize:live:apply": "tsx scripts/finalize-live.ts --apply",
    "deploy:railway": "tsx scripts/deploy-railway.ts",
    "deploy:railway:apply": "tsx scripts/deploy-railway.ts --apply",
    "railway:login": "pnpm dlx @railway/cli login",
    "railway:login:browserless": "pnpm dlx @railway/cli login --browserless",
    "railway:whoami": "pnpm dlx @railway/cli whoami",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22 <23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "prettier": "3.8.3",
    "tsx": "4.22.0",
    "typescript": "6.0.3"
  }
}
