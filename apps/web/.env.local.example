# Copy to apps/web/.env.local for local frontend development.
# In Vercel, set the same NEXT_PUBLIC_* values in Production before redeploying.

# Railway API used by the static dashboard for Wavy Node scoring.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Avalanche Fuji wallet/RPC config.
NEXT_PUBLIC_AVALANCHE_FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Filled after pnpm --filter @arkscore/contracts deploy:fuji.
NEXT_PUBLIC_CREDIT_SCORE_REGISTRY_ADDRESS=

# Optional Ava Labs EncryptedERC demo address.
NEXT_PUBLIC_EERC20_DEMO_ADDRESS=

# Keep false for the final live Wavy-backed deployment.
# Set true only for a hosted fallback judge demo before Railway credentials exist.
NEXT_PUBLIC_ENABLE_DEMO_FALLBACK=false
